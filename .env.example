# Copy this to .env.local for local development
# Add these same keys in Netlify → Site Settings → Environment Variables

# Turso database (frontend — must be prefixed VITE_)
VITE_TURSO_URL=https://vas-lab-booking-yourorg.turso.io
VITE_TURSO_TOKEN=your-turso-auth-token

# Turso database (Netlify functions — no VITE_ prefix)
TURSO_URL=https://vas-lab-booking-yourorg.turso.io
TURSO_TOKEN=your-turso-auth-token

# Resend email API (Netlify functions only)
RESEND_API_KEY=your-resend-api-key
